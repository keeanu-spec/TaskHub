<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="taskhub" transaction-type="RESOURCE_LOCAL">
        <!-- Entidades gestionadas por JPA -->
        <class>org.example.domain.User</class>
        <class>org.example.domain.Project</class>
        <class>org.example.domain.Task</class>

        <properties>
            <!-- Conexión H2 en archivo para persistir entre reinicios -->
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:./data/taskhub_jpa;AUTO_SERVER=TRUE;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <!-- Hibernate crea tablas si no existen, no falla en reinicios -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Dialecto H2 para Hibernate 6 -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>

            <!-- Mostrar SQL en consola — útil para depurar, desactivar en producción -->
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
